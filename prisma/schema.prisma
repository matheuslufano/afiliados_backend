generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  city      String?
  createdAt DateTime @default(now())

  links Link[]
}

model Affiliate {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  links Link[]
} 

model Campaign {
  id             Int      @id @default(autoincrement())
  name           String
  destinationUrl String
  createdAt      DateTime @default(now())

  links Link[]
}

model Link {
  id           Int      @id @default(autoincrement())
  name         String?
  originalUrl  String
  shortCode    String   @unique
  affiliateUrl String?
  createdAt    DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  affiliateId Int?
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])

  campaignId Int?
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  clicks Click[]
  conversions Conversion[]
}

model Click {
  id         Int      @id @default(autoincrement())
  ipAddress  String?
  userAgent  String?
  clickedAt  DateTime @default(now())

  linkId Int
  link   Link @relation(fields: [linkId], references: [id])
}

model Conversion {
  id          Int      @id @default(autoincrement())
  type        String   @default("whatsapp")
  product     String?
  destination String?
  visitorName String?
  visitorPhone String?
  visitorCity String?
  source      String?
  ipAddress   String?
  userAgent   String?
  convertedAt DateTime @default(now())

  linkId Int
  link   Link @relation(fields: [linkId], references: [id])
}
