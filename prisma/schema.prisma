generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  city      String?
  photoUrl  String?
  createdAt DateTime @default(now())

  links Link[]
}

model Affiliate {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  city      String?
  photoUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  links Link[]
} 

model Campaign {
  id             Int      @id @default(autoincrement())
  name           String
  destinationUrl String
  createdAt      DateTime @default(now())

  links Link[]
}

model Link {
  id           Int      @id @default(autoincrement())
  name         String?
  originalUrl  String
  shortCode    String   @unique
  affiliateUrl String?
  createdAt    DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  affiliateId Int?
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])

  campaignId Int?
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  clicks Click[]
  conversions Conversion[]
}

model Click {
  id              Int      @id @default(autoincrement())
  ipAddress       String?
  userAgent       String?
  referrer        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  source          String?
  deviceType      String?
  browser         String?
  operatingSystem String?
  platform        String?
  language        String?
  geoCountry      String?
  geoRegion       String?
  geoCity         String?
  timezone        String?
  screenWidth     Int?
  screenHeight    Int?
  clickedAt       DateTime @default(now())

  linkId Int
  link   Link @relation(fields: [linkId], references: [id])
}

model Conversion {
  id              Int      @id @default(autoincrement())
  type            String   @default("whatsapp")
  product         String?
  destination     String?
  visitorName     String?
  visitorPhone    String?
  visitorDocument String?
  visitorCity     String?
  source          String?
  ipAddress       String?
  userAgent       String?
  referrer        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  deviceType      String?
  browser         String?
  operatingSystem String?
  platform        String?
  language        String?
  geoCountry      String?
  geoRegion       String?
  geoCity         String?
  timezone        String?
  screenWidth     Int?
  screenHeight    Int?
  convertedAt     DateTime @default(now())

  linkId Int
  link   Link @relation(fields: [linkId], references: [id])
}

model WebhookLog {
  id              Int      @id @default(autoincrement())
  provider        String
  attendanceId    String?
  channelName     String?
  channelType     String?
  eventStatus     String?
  shortCode       String?
  conversionId    Int?
  linkId          Int?
  visitorName     String?
  visitorPhone    String?
  visitorDocument String?
  ipAddress       String?
  userAgent       String?
  raw             Json
  query           Json
  result          Json
  receivedAt      DateTime @default(now())

  @@index([provider, receivedAt])
  @@index([attendanceId])
  @@index([shortCode])
}
